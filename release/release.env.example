# Copy to release/release.env and fill local-only values.
# Do not commit release/release.env.

APP_NAME="HerdWatch"
SCHEME="HerdWatch"
CONFIGURATION="Release"
BUNDLE_ID="com.isaji134.HerdWatch"

# Developer ID signing. Example:
# DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"
DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"
DEVELOPMENT_TEAM="TEAMID"

# Create once with:
# xcrun notarytool store-credentials herdwatch-notary --apple-id you@example.com --team-id TEAMID --password app-specific-password
NOTARY_PROFILE="herdwatch-notary"

# Public URL where the contents of dist/ are uploaded.
# For R2 public r2.dev, use something like:
# PUBLIC_BASE_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev/herdwatch"
PUBLIC_BASE_URL="https://pub-xxxxxxxxxxxxxxxx.r2.dev/herdwatch"

# Sparkle's sign_update binary. Required for a usable appcast.xml.
# Example after adding Sparkle to the app project:
# SPARKLE_SIGN_UPDATE="/path/to/Sparkle/bin/sign_update"
SPARKLE_SIGN_UPDATE=""

# Optional appcast metadata.
RELEASE_NOTES_URL=""
MINIMUM_SYSTEM_VERSION="26.0"
